generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String    @id @default(cuid())
  name          String
  settings      String?   @db.Text
  status        String    @default("trial")   // trial | active | inactive | pending_deletion
  plan          String    @default("trial")   // trial | starter | pro | enterprise
  trialEndsAt   DateTime?
  maxUsers      Int       @default(5)
  aiTokensLimit Int       @default(10000)
  aiTokensUsed  Int       @default(0)
  deletionRequestedAt   DateTime?
  dataExportRequestedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users           User[]
  clients         Client[]
  suppliers       Supplier[]
  supplierBills        SupplierBill[]
  supplierBillPayments SupplierBillPayment[]
  categories      Category[]
  products        Product[]
  employees       Employee[]
  invoices        Invoice[]
  auditLogs       AuditLog[]
  payments        Payment[]
  expenses        Expense[]
  accounts        Account[]
  journalEntries  JournalEntry[]
  salaryAdvances  SalaryAdvance[]
  clientPayments  ClientPayment[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  username       String?      @unique
  password       String
  name           String
  role           String       @default("employee")
  permissions    String?      @db.Text
  theme          String       @default("dark")
  language       String       @default("en")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  resetCode      String?
  resetCodeExp   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  expenses       Expense[]

  @@index([organizationId])
}

model SupplierBill {
  id             String               @id @default(cuid())
  supplierId     String
  supplier       Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amount         Float
  description    String
  reference      String?
  date           DateTime
  dueDate        DateTime?
  status         String               @default("pending")   // pending | partially_paid | paid
  amountPaid     Float                @default(0)
  note           String?              @db.Text
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  payments       SupplierBillPayment[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([supplierId])
  @@index([organizationId])
  @@index([status])
}

model SupplierBillPayment {
  id             String       @id @default(cuid())
  billId         String
  bill           SupplierBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount         Float
  date           DateTime
  method         String       @default("cash")
  note           String?      @db.Text
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([billId])
  @@index([organizationId])
}

model Client {
  id             String          @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?         @db.Text
  city           String?
  country        String?
  taxId          String?
  notes          String?         @db.Text
  balance        Float           @default(0)
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  invoices       Invoice[]
  clientPayments ClientPayment[]

  @@index([organizationId])
}

model ClientPayment {
  id             String       @id @default(cuid())
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount         Float
  applied        Float
  date           DateTime
  method         String       @default("cash")
  reference      String?
  note           String?      @db.Text
  invoicesSummary String?     @db.Text   // JSON: [{invoiceId, invoiceNumber, amount, newStatus}]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([clientId])
  @@index([organizationId])
  @@index([date])
}

model Category {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  products       Product[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model Product {
  id             String             @id @default(cuid())
  name           String
  sku            String
  description    String?            @db.Text
  price          Float
  cost           Float              @default(0)
  quantity       Float              @default(0)
  minStock       Int                @default(5)
  unit           String             @default("piece")
  type           String             @default("simple")   // simple | composite
  categoryId     String?
  category       Category?          @relation(fields: [categoryId], references: [id])
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  invoiceItems   InvoiceItem[]
  components     ProductComponent[] @relation("CompositeProduct")
  usedIn         ProductComponent[] @relation("ComponentProduct")

  @@unique([sku, organizationId])
  @@index([organizationId])
}

model ProductComponent {
  id          String  @id @default(cuid())
  compositeId String
  composite   Product @relation("CompositeProduct", fields: [compositeId], references: [id], onDelete: Cascade)
  componentId String
  component   Product @relation("ComponentProduct", fields: [componentId], references: [id])
  quantity    Float

  @@unique([compositeId, componentId])
  @@index([compositeId])
  @@index([componentId])
}

model Employee {
  id             String          @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  position       String
  department     String?
  salary         Float
  salaryPeriod   String          @default("month")   // day | week | month
  currency       String          @default("USD")
  hireDate       DateTime        @default(now())
  status         String          @default("active")
  address        String?         @db.Text
  notes          String?         @db.Text
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  salaryAdvances SalaryAdvance[]

  @@index([organizationId])
}

model SalaryAdvance {
  id             String       @id @default(cuid())
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount         Float
  date           DateTime
  status         String       @default("pending")   // pending | returned | paid
  note           String?      @db.Text
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([employeeId])
  @@index([organizationId])
}

model Invoice {
  id             String        @id @default(cuid())
  number         String
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  date           DateTime      @default(now())
  dueDate        DateTime?
  status         String        @default("draft")
  subtotal       Float         @default(0)
  discount       Float         @default(0)
  tax            Float         @default(0)
  taxRate        Float         @default(19)
  total          Float         @default(0)
  notes          String?       @db.Text
  language       String        @default("en")
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          InvoiceItem[]
  fees           InvoiceFee[]
  payments       Payment[]

  @@unique([number, organizationId])
  @@index([organizationId])
}

model Payment {
  id             String       @id @default(cuid())
  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount         Float
  date           DateTime     @default(now())
  method         String       @default("cash")
  reference      String?
  note           String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([invoiceId])
  @@index([organizationId])
}

model Expense {
  id             String       @id @default(cuid())
  date           DateTime
  amount         Float
  description    String
  category       String
  recurrence     String       @default("none")
  vendor         String?
  reference      String?
  note           String?      @db.Text
  accountId      String?
  account        Account?     @relation(fields: [accountId], references: [id])
  supplierId     String?
  supplier       Supplier?    @relation(fields: [supplierId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String?
  createdBy      User?        @relation(fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([date])
}

model Account {
  id             String        @id @default(cuid())
  code           String
  name           String
  type           String
  subtype        String?
  description    String?
  isDefault      Boolean       @default(false)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  expenses       Expense[]
  journalLines   JournalLine[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([code, organizationId])
  @@index([organizationId])
}

model JournalEntry {
  id             String        @id @default(cuid())
  date           DateTime
  description    String
  reference      String?
  type           String        @default("manual")
  sourceId       String?
  lines          JournalLine[]
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([date])
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Float        @default(0)
  credit         Float        @default(0)
  description    String?

  @@index([journalEntryId])
  @@index([accountId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Int
  unitPrice   Float
  unitCost    Float  @default(0)
  total       Float
}

model InvoiceFee {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  label     String
  amount    Float

  @@index([invoiceId])
}

model AuditLog {
  id             String       @id @default(cuid())
  userId         String
  userName       String
  userEmail      String
  action         String
  entity         String
  entityId       String?
  description    String       @db.Text
  method         String       @default("manual")
  metadata       String?      @db.Text
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@index([method])
}

model PlatformConfig {
  id                   String   @id @default("singleton")
  defaultAiTokensLimit Int      @default(10000)
  defaultTrialDays     Int      @default(15)
  defaultMaxUsers      Int      @default(5)
  updatedAt            DateTime @updatedAt
}

model Supplier {
  id             String       @id @default(cuid())
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?      @db.Text
  city           String?
  country        String?
  taxId          String?
  paymentTerms   Int?         // days e.g. 30, 60, 90
  notes          String?      @db.Text
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  expenses       Expense[]
  bills          SupplierBill[]

  @@index([organizationId])
}
